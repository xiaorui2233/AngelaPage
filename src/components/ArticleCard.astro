---
interface Props { post: any; }
const { post } = Astro.props;
---

<a href={`/AngelaPage/posts/${post.slug}`} class="article-card">
  <div class="meta">
    <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
    {post.data.category && <span class="category">{post.data.category}</span>}
  </div>
  <h3>{post.data.title}</h3>
  <p>{post.data.description}</p>
  {post.data.tags && (
    <div class="tags">
      {post.data.tags.slice(0, 3).map((tag: string) => <span>{tag}</span>)}
    </div>
  )}
</a>

<style>
  .article-card { display: block; text-decoration: none; color: inherit; border: 1px solid var(--border); border-radius: 14px; background: var(--card); padding: 1rem 1.2rem; transition: transform 0.2s ease, border-color 0.2s ease; }
  .article-card:hover { transform: translateY(-2px); border-color: var(--accent); }
  h3 { margin: 0.45rem 0; font-size: 1.1rem; }
  p { margin: 0; color: var(--text-secondary); line-height: 1.6; font-size: 0.95rem; }
  .meta { display: flex; gap: 0.6rem; color: var(--text-muted); font-size: 0.83rem; }
  .category { border: 1px solid var(--border); border-radius: 999px; padding: 0.05rem 0.5rem; }
  .tags { margin-top: 0.8rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tags span { font-size: 0.75rem; color: var(--accent); background: color-mix(in oklab, var(--accent) 13%, transparent); border-radius: 999px; padding: 0.2rem 0.5rem; }
</style>
