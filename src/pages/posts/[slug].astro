---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts }
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
const readingTime = Math.max(1, Math.round(post.body.length / 450));

const relatedPosts = allPosts
  .filter((item: any) => item.slug !== post.slug)
  .map((item: any) => {
    const overlap = (item.data.tags ?? []).filter((tag: string) => (post.data.tags ?? []).includes(tag)).length;
    return { item, score: overlap };
  })
  .filter((entry: any) => entry.score > 0)
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 3)
  .map((entry: any) => entry.item);
---

<BaseLayout title={`${post.data.title} | Angela Blog`} description={post.data.description}>
  <article class="post-grid">
    <div class="post-main">
      {post.data.cover && (
        <div class="post-cover">
          <img src={post.data.cover} alt={post.data.title} loading="lazy" />
        </div>
      )}

      <header class="post-header">
        <p class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
          <span>·</span>
          <span>{readingTime} min read</span>
          {post.data.category && (
            <>
              <span>·</span>
              <span>{post.data.category}</span>
            </>
          )}
        </p>
        <h1>{post.data.title}</h1>
        {post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/AngelaPage/tags/${tag}`}>{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>

      {relatedPosts.length > 0 && (
        <section class="related">
          <h2>相关文章</h2>
          <ul>
            {relatedPosts.map((item: any) => (
              <li><a href={`/AngelaPage/posts/${item.slug}`}>{item.data.title}</a></li>
            ))}
          </ul>
        </section>
      )}
    </div>

    <aside class="toc">
      <div class="toc-panel">
        <h3>目录</h3>
        {headings.length > 0 ? (
          <ul>
            {headings.filter((h) => h.depth <= 3).map((heading) => (
              <li class={`depth-${heading.depth}`}><a href={`#${heading.slug}`}>{heading.text}</a></li>
            ))}
          </ul>
        ) : (
          <p>这篇文章暂无目录结构。</p>
        )}
      </div>
    </aside>
  </article>


  <script is:inline>
    (() => {
      const root = document.querySelector('.prose');
      if (!root) return;
      const imgs = root.querySelectorAll('img');
      imgs.forEach((img) => {
        const src = img.getAttribute('src') || '';
        if (src.startsWith('/images/')) {
          img.setAttribute('src', `/AngelaPage${src}`);
        } else if (!src.startsWith('http') && !src.startsWith('/AngelaPage/') && !src.startsWith('data:')) {
          img.setAttribute('src', `/AngelaPage/${src.replace(/^\/+/, '')}`);
        }
        img.setAttribute('loading', 'lazy');

        if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(src)) {
          const video = document.createElement('video');
          video.setAttribute('src', img.getAttribute('src') || src);
          video.setAttribute('controls', '');
          video.setAttribute('preload', 'metadata');
          if (img.getAttribute('alt')) video.setAttribute('title', img.getAttribute('alt'));
          img.replaceWith(video);
        }
      });

      const wrapMedia = (el) => {
        if (!el || el.closest('.video-embed')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'video-embed';
        el.parentNode?.insertBefore(wrapper, el);
        wrapper.appendChild(el);
      };

      root.querySelectorAll('iframe').forEach(wrapMedia);
      root.querySelectorAll('video').forEach(wrapMedia);

      const isStandaloneLink = (anchor) => {
        const parent = anchor?.parentElement;
        if (!parent || parent.tagName.toLowerCase() !== 'p') return false;
        if (parent.querySelectorAll('a').length !== 1) return false;
        return parent.textContent?.trim() === anchor.textContent?.trim();
      };

      const isMarkedEmbed = (anchor) => {
        const text = anchor?.textContent?.trim().toLowerCase() || '';
        return text === 'embed' || text === 'video' || text.startsWith('embed:') || text.startsWith('video:');
      };


      const getYouTubeId = (url) => {
        try {
          const u = new URL(url, window.location.href);
          if (u.hostname.includes('youtu.be')) return u.pathname.replace('/', '');
          if (!u.hostname.includes('youtube.com')) return '';
          if (u.pathname.startsWith('/embed/')) return u.pathname.split('/')[2] || '';
          if (u.pathname.startsWith('/shorts/')) return u.pathname.split('/')[2] || '';
          return u.searchParams.get('v') || '';
        } catch { return ''; }
      };

      const getBilibiliId = (url) => {
        try {
          const u = new URL(url, window.location.href);
          if (!u.hostname.includes('bilibili.com')) return null;
          const bvid = u.searchParams.get('bvid');
          if (bvid && /^BV[0-9A-Za-z]+$/.test(bvid)) return { bvid };
          const match = u.pathname.match(/\/video\/(BV[0-9A-Za-z]+|av\d+)/i);
          if (!match) return null;
          if (match[1].toLowerCase().startsWith('bv')) return { bvid: match[1] };
          return { aid: match[1].replace(/^av/i, '') };
        } catch { return null; }
      };

      const buildEmbed = (url) => {
        const ytId = getYouTubeId(url);
        if (ytId) {
          return `<iframe src="https://www.youtube.com/embed/${ytId}" title="YouTube video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen loading="lazy"></iframe>`;
        }
        const bilibili = getBilibiliId(url);
        if (bilibili?.bvid) {
          return `<iframe src="https://player.bilibili.com/player.html?bvid=${bilibili.bvid}&page=1&high_quality=1" title="Bilibili video" allowfullscreen loading="lazy"></iframe>`;
        }
        if (bilibili?.aid) {
          return `<iframe src="https://player.bilibili.com/player.html?aid=${bilibili.aid}&page=1&high_quality=1" title="Bilibili video" allowfullscreen loading="lazy"></iframe>`;
        }
        if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(url)) {
          return `<video src="${url}" controls preload="metadata"></video>`;
        }
        return '';
      };

      root.querySelectorAll('a').forEach((a) => {
        if (!isStandaloneLink(a)) return;
        if (!isMarkedEmbed(a)) return;
        const href = a.getAttribute('href') || '';
        const embed = buildEmbed(href);
        if (!embed) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'video-embed';
        wrapper.innerHTML = embed;
        a.parentElement?.replaceWith(wrapper);
      });
    })();
  </script>

</BaseLayout>

<style>
  .post-grid { display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 1.2rem; }
  .post-main { border: 1px solid var(--border); border-radius: 14px; background: var(--card); padding: 1.4rem; }
  .post-cover { margin: -1.4rem -1.4rem 1rem; height: clamp(180px, 30vw, 300px); overflow: hidden; border-radius: 14px 14px 0 0; border-bottom: 1px solid var(--border); background: var(--surface); }
  .post-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .meta { margin: 0; color: var(--text-muted); display: flex; gap: 0.45rem; align-items: center; font-size: 0.92rem; }
  h1 { margin: 0.7rem 0 0.8rem; font-size: clamp(1.6rem, 3.4vw, 2.3rem); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .tags a { color: var(--accent); text-decoration: none; border: 1px solid var(--border); border-radius: 999px; padding: 0.2rem 0.6rem; font-size: 0.8rem; }

  .prose { line-height: 1.85; color: var(--text-secondary); }
  .prose :global(h2), .prose :global(h3) { color: var(--text-primary); margin-top: 1.4rem; }
  .prose :global(pre) { overflow-x: auto; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 0.8rem; }
  .prose :global(code) { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .prose :global(img) { width: 100%; max-width: 100%; border-radius: 12px; border: 1px solid var(--border); margin: 1rem 0; display: block; }
  .prose :global(iframe) { width: 100%; max-width: 100%; border-radius: 12px; border: 1px solid var(--border); margin: 1rem 0; display: block; }
  .prose :global(video) { width: 100%; max-width: 100%; border-radius: 12px; border: 1px solid var(--border); margin: 1rem 0; display: block; background: #000; }
  .prose :global(.video-embed) { position: relative; width: 100%; aspect-ratio: 16 / 9; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin: 1rem 0; }
  .prose :global(.video-embed iframe),
  .prose :global(.video-embed video),
  .prose :global(.video-embed embed) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; margin: 0; }
  .prose :global(figure) { margin: 1rem 0; }
  .prose :global(figcaption) { color: var(--text-muted); font-size: 0.85rem; text-align: center; margin-top: .4rem; }

  .related { margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.2rem; }
  .related h2 { margin: 0 0 0.8rem; font-size: 1.1rem; }
  .related ul { margin: 0; padding-left: 1.2rem; }
  .related a { color: var(--accent); text-decoration: none; }

  .toc-panel { position: sticky; top: 86px; border: 1px solid var(--border); border-radius: 12px; padding: 1rem; background: var(--card); }
  .toc-panel h3 { margin: 0 0 0.7rem; font-size: 1rem; }
  .toc-panel ul { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.4rem; }
  .toc-panel a { color: var(--text-secondary); text-decoration: none; font-size: 0.88rem; }
  .toc-panel .depth-3 { padding-left: 0.8rem; }

  @media (max-width: 980px) {
    .post-grid { grid-template-columns: 1fr; }
    .toc { order: -1; }
    .toc-panel { position: static; }
  }
</style>
