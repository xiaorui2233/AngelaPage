---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const latest = posts.slice(1, 7);

const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Home | Angela Blog" description="Angela 的个人技术博客，记录学习、创作与灵感。">
  <section class="hero">
    <p class="eyebrow">Angela Blog</p>
    <h1>为热爱创造，为成长记录。</h1>
    <p class="lead">一个面向阅读体验的个人博客：前端、设计、生活观察。</p>
    <div class="hero-actions">
      <a href="/AngelaPage/archive" class="btn primary">开始阅读</a>
      <a href="/AngelaPage/about" class="btn">了解我</a>
    </div>
  </section>

  <div class="home-grid">
    <div class="content-area">
      {featured && (
        <section class="featured">
          <p class="section-label">Featured Post</p>
          <a href={`/AngelaPage/posts/${featured.slug}`} class="featured-card">
            <div class="featured-content">
              <h2>{featured.data.title}</h2>
              <p>{featured.data.description}</p>
              <span>继续阅读 →</span>
            </div>
            {featured.data.cover && (
              <div class="featured-cover" aria-hidden="true">
                <img src={featured.data.cover} alt="" loading="lazy" />
              </div>
            )}
          </a>
        </section>
      )}

      <section>
        <p class="section-label">Latest Posts</p>
        <div class="post-list">
          {latest.map((post) => <ArticleCard post={post} />)}
        </div>
      </section>
    </div>

    <Sidebar tags={tags} recent={posts} />
  </div>
</BaseLayout>

<style>
  .hero { padding: 1.4rem 0 2.4rem; }
  .eyebrow { margin: 0 0 0.5rem; color: var(--accent); font-weight: 600; }
  h1 { margin: 0; font-size: clamp(1.8rem, 4vw, 2.8rem); letter-spacing: -0.02em; }
  .lead { color: var(--text-secondary); max-width: 680px; line-height: 1.7; margin-top: 0.8rem; }
  .hero-actions { display: flex; gap: 0.7rem; margin-top: 1.4rem; }
  .btn { border: 1px solid var(--border); border-radius: 10px; padding: 0.52rem 0.9rem; text-decoration: none; color: var(--text-primary); background: var(--card); }
  .btn.primary { background: var(--accent); border-color: var(--accent); color: white; }

  .home-grid { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 1.2rem; }
  .content-area { display: grid; gap: 1.2rem; }

  .section-label { margin: 0 0 0.7rem; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .featured-card { display: grid; grid-template-columns: minmax(0, 1fr) 220px; gap: 1rem; text-decoration: none; color: inherit; background: linear-gradient(140deg, color-mix(in oklab, var(--accent) 18%, var(--card)), var(--card)); border: 1px solid var(--border); border-radius: 16px; padding: 1.2rem; align-items: center; }
  .featured-card h2 { margin: 0; }
  .featured-card p { color: var(--text-secondary); margin: 0.6rem 0 1rem; }
  .featured-card span { color: var(--accent); font-weight: 600; }
  .featured-cover { width: 100%; height: 130px; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); }
  .featured-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .post-list { display: grid; gap: 0.8rem; }

  @media (max-width: 980px) {
    .home-grid { grid-template-columns: 1fr; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-cover { height: 180px; }
  }
</style>
